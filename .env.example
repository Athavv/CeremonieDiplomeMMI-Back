## Backend Environment Variables
## DO NOT COMMIT THIS FILE - Use .env.example for git

# Database Configuration - TiDB Cloud
# Format: jdbc:mysql://host:port/database?useSSL=true&serverTimezone=UTC
SPRING_DATASOURCE_URL=jdbc:mysql://your-tidb-host:4000/diplomemmi?useSSL=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=your_user@your_cluster
SPRING_DATASOURCE_PASSWORD=your_password

# JPA/Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# JWT Security
APPLICATION_SECURITY_JWT_SECRET_KEY=4503dc4b267eb0db9bbb3ef12f64335efeddf46ed53b3327ed7cc8a7020f2cec
APPLICATION_SECURITY_JWT_EXPIRATION=86400000
APPLICATION_SECURITY_JWT_REFRESH_TOKEN_EXPIRATION=604800000

# Server
SERVER_PORT=8080

# File Upload
APP_UPLOADS_DIRECTORY=uploads
